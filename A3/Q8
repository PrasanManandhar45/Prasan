'''Library Management System using OOP and file handling'''

import os

class Library:
    def __init__(self, filename="books.txt"):
        self.filename = filename
        
        # Create file if not exists
        if not os.path.exists(self.filename):
            open(self.filename, "w").close()

    def add_book(self, title):
        with open(self.filename, "a") as f:
            f.write(f"{title},available\n")

    def view_books(self):
        with open(self.filename, "r") as f:
            data = f.read()
            print("\nBooks List:")
            print(data if data else "No books found")

    def borrow_book(self, title):
        lines = []
        found = False

        with open(self.filename, "r") as f:
            for line in f:
                name, status = line.strip().split(",")

                if name == title and status == "available":
                    lines.append(f"{name},borrowed\n")
                    found = True
                else:
                    lines.append(line)

        with open(self.filename, "w") as f:
            f.writelines(lines)

        print("Book borrowed successfully" if found else "Book not available")

    def return_book(self, title):
        lines = []
        found = False

        with open(self.filename, "r") as f:
            for line in f:
                name, status = line.strip().split(",")

                if name == title and status == "borrowed":
                    lines.append(f"{name},available\n")
                    found = True
                else:
                    lines.append(line)

        with open(self.filename, "w") as f:
            f.writelines(lines)

        print("Book returned successfully" if found else "Book not found")

    def search_book(self, title):
        found = False

        with open(self.filename, "r") as f:
            for line in f:
                name, status = line.strip().split(",")
                if name == title:
                    print(f"{name} -> {status}")
                    found = True

        if not found:
            print("Book not found")


# Main Program
lib = Library()

while True:
    print("\n1. Add Book")
    print("2. View Books")
    print("3. Borrow Book")
    print("4. Return Book")
    print("5. Search Book")
    print("6. Exit")

    choice = input("Enter choice: ")

    try:
        if choice == "1":
            lib.add_book(input("Enter book name: "))

        elif choice == "2":
            lib.view_books()

        elif choice == "3":
            lib.borrow_book(input("Enter book name: "))

        elif choice == "4":
            lib.return_book(input("Enter book name: "))

        elif choice == "5":
            lib.search_book(input("Enter book name: "))

        elif choice == "6":
            print("Exiting...")
            break

        else:
            print("Invalid choice")

    except Exception as e:
        print("Error:", e)