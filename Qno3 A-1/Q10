import random

number = random.randint(1, 50)
attempts = 7

for i in range(attempts):
    guess = int(input("Guess the number (1-50): "))

    if guess > number:
        print("Too high")
    elif guess < number:
        print("Too low")
    else:
        print("Correct! You win!")
        break
else:
    print("Better luck next time! The number was:", number)