import math

num = float(input("Enter a number: "))

print("Cube:", num ** 3)

print("Cube root:", num ** (1/3))

if num > 0:
    print("Natural log:", math.log(num))
    print("Base-2 log:", math.log2(num))
else:
    print("Logarithm not defined for non-positive numbers")

print("Power 6:", num ** 6)
