def basic_operations(a, b):
    print("Sum:", a + b)
    print("Difference:", a - b)
    print("Product:", a * b)
    if b != 0:
        print("Quotient:", a / b)
    else:
        print("Cannot divide by zero")

a = int(input("Enter first number: "))
b = int(input("Enter second number: "))
basic_operations(a, b)